{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "serve:php": "php -S 127.0.0.1:8080 -t public",
        "dev:full": "concurrently -n \"php,vite\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run serve:php\" \"npm run dev\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@vitejs/plugin-vue": "^6.0.5",
        "vue": "^3.5.30",
        "vue-router": "^4.6.4"
    }
}
